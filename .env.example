# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=cake_mall_user
DB_PASSWORD=your_strong_password_here
DB_NAME=cake_mall

# JWT密钥（请生成随机字符串，至少32位）
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# 前端地址（生产环境改为你的域名）
FRONTEND_URL=https://your-domain.com

# 管理员初始密码
ADMIN_EMAIL=admin@cake-mall.com
ADMIN_PASSWORD=your_admin_password_here

# 骑手初始密码
RIDER_EMAIL=rider@cake-mall.com
RIDER_PASSWORD=your_rider_password_here

# 端口
PORT=3000
